{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=CodeMasterDB;User ID=root;Password=your_mysql_password;Character Set=utf8mb4;SslMode=None;AllowPublicKeyRetrieval=True;"
  },
  "DbProvider": "MySql",
  "Portal": {
    "AdminAppUrl": "/index.html#/login",
    "AdminLoginUrl": "/index.html#/login"
  },
  "Authentication": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackUrl": "http://localhost:5000/api/account/github/callback"
    }
  },
  "Email": {
    "Provider": "None",
    "From": "",
    "CodeSecret": "CHANGE_ME_EMAIL_CODE_SECRET_AT_LEAST_32_CHARS",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "EnableSsl": true,
      "UserName": "",
      "Password": ""
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "CodeMaster",
    "Audience": "CodeMaster.WebApi",
    "ExpirationMinutes": 120
  },
  "SnowflakeId": {
    "WorkerId": 1
  },
  "Cache": {
    "Provider": "Memory",
    "DefaultExpiration": "01:00:00",
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "CodeMaster:"
    }
  }
}
