      "TypeDescription": "(index: string | number) => void"
    },
    {
      "Name": "prev",
      "Description": "切换至上一张幻灯片",
      "Type": "Function",
      "TypeDescription": "() => void"
    },
    {
      "Name": "next",
      "Description": "切换至下一张幻灯片",
      "Type": "Function",
      "TypeDescription": "() => void"
    }
