        query = query.WhereIF(input.{{ field.name }}Start.HasValue, e => e.{{ field.name }} >= input.{{ field.name }}Start.Value);
        query = query.WhereIF(input.{{ field.name }}End.HasValue, e => e.{{ field.name }} < input.{{ field.name }}End.Value.AddDays(1));
{{~ else if field.form_control_type == "datetime" ~}}
        query = query.WhereIF(input.{{ field.name }}Start.HasValue, e => e.{{ field.name }} >= input.{{ field.name }}Start.Value);
        query = query.WhereIF(input.{{ field.name }}End.HasValue, e => e.{{ field.name }} < input.{{ field.name }}End.Value.AddDays(1));
{{~ else if field.is_multiple && field.data_type == "string" ~}}
        if (!string.IsNullOrEmpty(input.{{ field.name }}))
        {
            var {{ field.name_lower }}Values = input.{{ field.name }}.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if ({{ field.name_lower }}Values.Length > 0)
            {
                var {{ field.name_lower }}Expression = Expressionable.Create<{{ entity.name }}>();
                foreach (var value in {{ field.name_lower }}Values)
                {
                    var current = value;
                    {{ field.name_lower }}Expression.Or(e => e.{{ field.name }} != null && ("," + e.{{ field.name }} + ",").Contains("," + current + ","));
                }
                query = query.Where({{ field.name_lower }}Expression.ToExpression());
            }
        }
{{~ else if field.data_type == "string" ~}}
        query = query.WhereIF(!string.IsNullOrEmpty(input.{{ field.name }}), e => e.{{ field.name }}!.Contains(input.{{ field.name }}!));
