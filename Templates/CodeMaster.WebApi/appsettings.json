{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Username=postgres;Password=postgres;Database=CodeMasterDB"
  },
  "DbProvider": "PostgreSQL",
  "Portal": {
    "AdminAppUrl": "/index.html#/login",
    "AdminLoginUrl": "/index.html#/login"
  },
  "Authentication": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackUrl": "http://localhost:5000/api/account/github/callback"
    }
  },
  "Email": {
    "Provider": "None",
    "From": "",
    "CodeSecret": "CHANGE_ME_EMAIL_CODE_SECRET_AT_LEAST_32_CHARS",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "EnableSsl": true,
      "UserName": "",
      "Password": ""
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "CodeMaster",
    "Audience": "CodeMaster.WebApi",
    "ExpirationMinutes": 120
  },
  "SnowflakeId": {
    "WorkerId": 1
  },
  "Cache": {
    "Provider": "Memory",
    "DefaultExpiration": "01:00:00",
    "Memory": {
      "SizeLimit": 1024,
      "CompactionPercentage": 0.25,
      "ExpirationScanFrequency": "00:05:00"
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "CodeMaster:",
      "ConnectTimeout": 5000,
      "SyncTimeout": 5000,
      "AbortOnConnectFail": false
    },
    "Hybrid": {
      "L1Expiration": "00:05:00",
      "L2Expiration": "01:00:00",
      "EnableL1": true,
      "EnableL2": true
    },
    "Policies": {
      "translation": {
        "Expiration": "24:00:00",
        "SlidingExpiration": false
      },
      "user": {
        "Expiration": "00:30:00",
        "SlidingExpiration": true
      },
      "temp": {
        "Expiration": "00:05:00",
        "SlidingExpiration": false
      }
    }
  }
}
